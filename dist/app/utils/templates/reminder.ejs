<!DOCTYPE html>
<html>
<head>
  <meta charset="UTF-8" />
  <title>Class Reminder</title>
  <style>
    body { font-family: Arial, sans-serif; background: #f7f7f7; color: #333; margin: 0; padding: 0; }
    .container { max-width: 500px; margin: 40px auto; background: #fff; padding: 30px; border-radius: 8px; box-shadow: 0 2px 8px rgba(0,0,0,0.08); }
    .badge { display: inline-block; padding: 6px 14px; background: #A9F877; color: #000; border-radius: 4px; font-weight: bold; margin: 10px 0 20px; }
    .info-row { margin: 10px 0; font-size: 15px; }
    .label { font-weight: bold; color: #555; }
    .btn { display: inline-block; margin-top: 24px; background: #A9F877; color: #000; font-weight: bold; padding: 12px 26px; border-radius: 6px; text-decoration: none; font-size: 15px; }
    .footer { margin-top: 32px; font-size: 12px; color: #888; border-top: 1px solid #f0f0f0; padding-top: 16px; }
  </style>
</head>
<body>
  <div class="container">
    <h2>Class Reminder 🔔</h2>
    <p>Hello <strong><%= recipientName %></strong>,</p>
    <p>This is a reminder that you have an upcoming class:</p>

    <span class="badge"><%= timeLabel %></span>

    <div class="info-row"><span class="label">📅 Date:</span> <%= date %></div>
    <div class="info-row"><span class="label">⏰ Time:</span> <%= startTime %></div>
    <div class="info-row"><span class="label">👨‍🏫 Teacher:</span> <%= teacherName %></div>
    <div class="info-row"><span class="label">👨‍🎓 Student:</span> <%= studentName %></div>

    <% if (meetLink) { %>
    <a href="<%= meetLink %>" class="btn">Join Class</a>
    <% } %>

    <p style="margin-top: 24px;">Please be ready on time. Good luck!</p>

    <div class="footer">&copy; Lenguable. All rights reserved.</div>
  </div>
</body>
</html>
