<!DOCTYPE html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>Class Cancelled</title>
  </head>
  <body style="margin: 0; padding: 0; background-color: #f9fafb; font-family: Arial, sans-serif;">
    <table width="100%" cellpadding="0" cellspacing="0" style="padding: 40px 0;">
      <tr>
        <td align="center">
          <table width="600" cellpadding="0" cellspacing="0" style="background-color: #ffffff; border: 1px solid #e5e7eb; border-radius: 8px; overflow: hidden; max-width: 600px; width: 100%;">

            <!-- Header -->
            <tr>
              <td style="background-color: #fee2e2; padding: 28px 32px;">
                <h1 style="margin: 0; color: #111827; font-size: 22px; font-weight: 700;">Class Cancelled</h1>
                <p style="margin: 6px 0 0; color: #374151; font-size: 14px;">A scheduled class has been cancelled</p>
              </td>
            </tr>

            <!-- Body -->
            <tr>
              <td style="padding: 32px;">
                <p style="margin: 0 0 24px; color: #374151; font-size: 15px;">
                  Hi <strong><%= recipientName %></strong>, a class has been cancelled by the <strong><%= cancelledBy %></strong>. Here are the details:
                </p>

                <!-- Info Table -->
                <table width="100%" cellpadding="0" cellspacing="0" style="border: 1px solid #e5e7eb; border-radius: 6px; overflow: hidden;">
                  <tr style="background-color: #f9fafb;">
                    <td style="padding: 12px 16px; color: #6b7280; font-size: 13px; width: 40%; border-bottom: 1px solid #e5e7eb;">Teacher</td>
                    <td style="padding: 12px 16px; color: #111827; font-size: 13px; font-weight: 600; border-bottom: 1px solid #e5e7eb;"><%= teacherName %></td>
                  </tr>
                  <tr>
                    <td style="padding: 12px 16px; color: #6b7280; font-size: 13px; border-bottom: 1px solid #e5e7eb;">Student</td>
                    <td style="padding: 12px 16px; color: #111827; font-size: 13px; font-weight: 600; border-bottom: 1px solid #e5e7eb;"><%= studentName %></td>
                  </tr>
                  <tr style="background-color: #f9fafb;">
                    <td style="padding: 12px 16px; color: #6b7280; font-size: 13px; border-bottom: 1px solid #e5e7eb;">Date</td>
                    <td style="padding: 12px 16px; color: #111827; font-size: 13px; border-bottom: 1px solid #e5e7eb;"><%= formattedDate %></td>
                  </tr>
                  <tr>
                    <td style="padding: 12px 16px; color: #6b7280; font-size: 13px; border-bottom: 1px solid #e5e7eb;">Time</td>
                    <td style="padding: 12px 16px; color: #111827; font-size: 13px; border-bottom: 1px solid #e5e7eb;"><%= formattedTime %></td>
                  </tr>
                  <tr style="background-color: #f9fafb;">
                    <td style="padding: 12px 16px; color: #6b7280; font-size: 13px; border-bottom: 1px solid #e5e7eb;">Cancelled By</td>
                    <td style="padding: 12px 16px; color: #111827; font-size: 13px; border-bottom: 1px solid #e5e7eb; text-transform: capitalize;"><%= cancelledBy %></td>
                  </tr>
                  <tr>
                    <td style="padding: 12px 16px; color: #6b7280; font-size: 13px; border-bottom: 1px solid #e5e7eb;">Reason</td>
                    <td style="padding: 12px 16px; color: #111827; font-size: 13px; border-bottom: 1px solid #e5e7eb;"><%= reason %></td>
                  </tr>
                  <tr style="background-color: #f9fafb;">
                    <td style="padding: 12px 16px; color: #6b7280; font-size: 13px;">Credit Refunded</td>
                    <td style="padding: 12px 16px; font-size: 13px; font-weight: 600;">
                      <% if (refunded) { %>
                        Yes — 1 credit returned to student
                      <% } else { %>
                        No — cancelled within 24 hours
                      <% } %>
                    </td>
                  </tr>
                </table>
              </td>
            </tr>

            <!-- Footer -->
            <tr>
              <td style="padding: 20px 32px; border-top: 1px solid #f3f4f6;">
                <p style="margin: 0; color: #9ca3af; font-size: 12px;">
                  This is an automated notification. Please do not reply to this email.
                </p>
              </td>
            </tr>

          </table>
        </td>
      </tr>
    </table>
  </body>
</html>